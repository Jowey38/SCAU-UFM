# Local-only G11 D-Flow FM runtime wiring (Windows paths).
# Copy this file to a shell-specific local env file if desired; do not commit
# actual machine paths or the runtime binaries/case companions.
DFLOWFM_SOURCE_DIR=H:/githubcode/SCAU-UFM/Delft3D-main
SCAU_DFLOWFM_LIBRARY_DEBUG=H:/githubcode/SCAU-UFM/configs/third_party/dflowfm/local_runtime/debug/dflowfm.dll
SCAU_DFLOWFM_LIBRARY_RELEASE=H:/githubcode/SCAU-UFM/configs/third_party/dflowfm/local_runtime/release/dflowfm.dll
DFLOWFM_SINGLE_REACH_MDU=H:/githubcode/SCAU-UFM/configs/third_party/dflowfm/local_runtime/cases/single_reach/Flow1D.mdu
DFLOWFM_RUNTIME_BIN_DEBUG=H:/githubcode/SCAU-UFM/Delft3D-main/install_fm-suite/bin
DFLOWFM_RUNTIME_BIN_RELEASE=H:/githubcode/SCAU-UFM/Delft3D-main/install_fm-suite_release/bin
